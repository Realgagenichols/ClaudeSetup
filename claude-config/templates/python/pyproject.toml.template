[project]
name = "{{project_name}}"
version = "0.1.0"
description = "{{description}}"
requires-python = ">=3.12"
dependencies = []

[project.scripts]
{{project_name}} = "{{package_name}}.main:main"

[dependency-groups]
dev = [
    "pytest>=8.0",
    "ruff>=0.4",
]

[tool.pytest.ini_options]
testpaths = ["tests"]
markers = [
    "regression: tests for previously caught bugs",
]

[tool.ruff]
target-version = "py312"
line-length = 100

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B", "SIM"]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

# Uncomment if package directory name differs from project name
# [tool.hatch.build.targets.wheel]
# packages = ["{{package_name}}"]
